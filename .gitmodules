[submodule "zsh/.oh-my-zsh"]
	path = laptop/zsh/.oh-my-zsh
	url = git://github.com/robbyrussell/oh-my-zsh.git
[submodule "vim/.vim/bundle/base16-vim"]
	path = laptop/vim/.vim/bundle/base16-vim
	url = https://github.com/chriskempson/base16-vim.git
[submodule "vim/.vim/bundle/vim-python-pep8-indent"]
	path = laptop/vim/.vim/bundle/vim-python-pep8-indent
	url = https://github.com/Vimjas/vim-python-pep8-indent.git
[submodule "zsh/.config/base16-shell"]
	path = laptop/zsh/.config/base16-shell
	url = https://github.com/chriskempson/base16-shell
[submodule "desktop/zsh/.oh-my-zsh/custom/plugins/base16-shell"]
	path = desktop/zsh/.oh-my-zsh/custom/plugins/base16-shell
	url = https://github.com/chriskempson/base16-shell.git
[submodule "desktop/zsh/.oh-my-zsh/custom/themes/powerlevel10k"]
	path = desktop/zsh/.oh-my-zsh/custom/themes/powerlevel10k
	url = https://github.com/romkatv/powerlevel10k.git
