{
  "layer": "top",
  "height": 60,
  "width": 2560,
  "reload_style_on_change": true,
  "modules-left": ["river/tags", "custom/river-mode"],
  "modules-center": ["river/window"],
  "modules-right": [
    "custom/clipboard",
    "cpu",
    "memory",
    "battery",
    "wireplumber",
    "network",
    "custom/weather",
    "clock",
    "custom/power"
  ],
  "river/tags": {
    "num-tags": 9,
    "tag-labels":["TERM", "WEB", "MAIL", "OFFICE", "CHAT", "MEDIA", "VM", "DL", "PWD"],
    "disable-click": false
  },
  // "river/mode": {
  //   "format": "MODE: {}",
  //   "tooltip" : false
  // },
  "custom/river-mode": {
    "exec": "cat ${XDG_RUNTIME_DIR}/river-mode",
    "format": "{}",
    "tooltip": false,
    "interval": "once",
    "signal": 8
  },
  "river/window": {
    "format": "{}",
    "max-length": 50,
    "tooltip" : false
  },
  "custom/clipboard": {
    "exec": "~/.local/bin/waybar-cliphist",
    "return-type": "json",
    "interval": "once",
    "format": "{icon}",
    "format-icons": {
      "empty": "󱘡",
      "full": "󰨸",
    },
    "on-click": "bash ~/.local/bin/cliphist-fuzzel",
    "on-click-right": "cliphist wipe; pkill -RTMIN+9 waybar; notify-send --app-name 'cliphist' --urgency 'normal' 'Clipboard' 'Database deleted'",
    "exec-on-event": true,
    "signal": 9,
  },
  "cpu": {
    "interval": 20,
    "format": " {usage}%",
    "tooltip": true
  },
  "memory": {
    "interval": 20,
    "format": "󰍛 {used:0.2f}GB",
    "tooltip": true,
    "states": {
      "warning": 85,
    },
  },
  "battery": {
      "states": { "warning": 30, "critical": 15 },
      "format-charging": " {capacity}%",
      "format-full": " 100%",
      "format": "{icon} {capacity}%",
      "format-icons": ["", "", "", "", ""]
  },
  "wireplumber": {
      "format": "{icon} {volume}% {format_source}",
      "format-muted": "  {format_source}",
      "format-source": "󰍬 {volume}%",
      "format-source-muted": "󰍭",
      "format-icons": {
          "default": ["", "", ""]
      },
      "scroll-step": 5.0,
      "on-click": "alacritty --class wiremix --title Wiremix --command zsh -ic wiremix",
      "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
      "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
  },
  "custom/weather": {
    "exec": "${HOME}/.local/bin/waybar-wttr Paris+France",
    "return-type": "json",
    "format": "{}",
    "tooltip": true,
    "interval": 3600
  },
  "network": {
    // "interface": "wlp5*", // (Optional) To force the use of this interface
    "format-wifi": " ({signalStrength}%)",
    "format-ethernet": "{ipaddr}/{cidr} ",
    "tooltip-format-wifi": "  {essid} ",
    "tooltip-format": "{ifname} via {gwaddr} ",
    "format-linked": "{ifname} (No IP) ",
    "format-disconnected": "Disconnected ⚠",
    "on-click": "alacritty --class impala --title Impala --command zsh -ic impala",
    // "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },
  "clock": {
    //"format": "   {:%A %d %B %Y     %H:%M}",
    //"format": "{:  %H:%M}",
    "format": "{:%A %d %B %Y  %H:%M}",
    "tooltip-format": "{:%D}\n{calendar}",
    /*"on-click": "gnome-calendar"*/
  },
  "custom/power": {
    "format": "  ",
    "on-click": "bash ~/.local/bin/powermenu",
    "tooltip": false
  },
  /*"temperature": {
   *  "hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
   *  "format": " {temperatureC}°C",
   *  "tooltip": false
   *},
   *"disk": {
   *  "interval": 3600,
   *  "format": "󰋊  {used}"
   * },
   */ 
}
