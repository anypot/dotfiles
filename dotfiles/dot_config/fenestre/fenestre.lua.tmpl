local function kb(keysym, mods, cmd)
	return { keysym = keysym, modifiers = mods, command = cmd }
end

local function spawn(prog)
	local cmd = { "spawn" }
	for arg in prog:gmatch("%S+") do
		cmd[#cmd + 1] = arg
	end
	return cmd
end

local function merge_rules(...)
	local result = {}
	for _, rules in ipairs({ ... }) do
		for _, rule in ipairs(rules) do
			table.insert(result, rule)
		end
	end
	return result
end

local function make_rules(entries, mode)
	local rules = {}
	for _, entry in ipairs(entries) do
		local rule = {
			mode = mode,
		}
		if type(entry) == "string" then
			rule.app_id = entry
		elseif type(entry) == "table" then
			for key, value in pairs(entry) do
				rule[key] = value
			end
		else
			error("Invalid rule entry type: " .. type(entry))
		end
		rules[#rules + 1] = rule
	end
	return rules
end

