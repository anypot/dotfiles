-- Super+{H,J,K,L}           = navigate between tiling windows
-- Super+Shift+{H,J,K,L}     = swap tiling windows or move floating windows
-- Super+Alt+{H,J,K,L}       = expand windows
-- Super+Shift+Alt+{H,J,K,L} = shrink windows
local dirs = { left = "h", down = "j", up = "k", right = "l" }
for dir, key in pairs(dirs) do
	kbs[#kbs + 1] = kb(key, super, "focus_" .. dir)
	kbs[#kbs + 1] = kb(key, supShift, "move_" .. dir)
	kbs[#kbs + 1] = kb(key, supAlt, "resize_expand_" .. dir)
	kbs[#kbs + 1] = kb(key, supAltShift, "resize_shrink_" .. dir)
	kbs[#kbs + 1] = kb(key, supCtrl, "focus_output_" .. dir)
end

