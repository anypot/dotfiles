#!/usr/bin/env bash

APPDIR="$HOME/Applications"

latest=$(ls -1t "$APPDIR"/ledger-live-desktop*.AppImage 2>/dev/null | head -n 1)
if [[ -z "$latest" ]]; then
  echo "No Ledger Live AppImage found in $APPDIR"
  exit 1
fi

# Optional global flags (edit as needed)
FLAGS=(
  # "--flag=value"
)

exec "$latest" "${FLAGS[@]}" "$@"
